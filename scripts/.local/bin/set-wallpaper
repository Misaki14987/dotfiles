#!/usr/bin/env bash
# Usage: set-wallpaper <image>
# Sets wallpaper via awww and regenerates theme via wallust, then reloads waybar.
set -euo pipefail

img="${1:-}"
if [[ -z "$img" || ! -f "$img" ]]; then
    echo "usage: set-wallpaper <image>" >&2
    exit 1
fi

# Ensure awww daemon is running
if ! pidof awww-daemon >/dev/null; then
    awww-daemon >/dev/null 2>&1 &
    sleep 0.4
fi

awww img "$img" \
    --transition-type grow \
    --transition-pos center \
    --transition-duration 1 \
    --transition-fps 60

# Extract palette and render templates (including waybar colors.css)
wallust run "$img"

# Reload waybar to pick up new colors
pkill -SIGUSR2 waybar 2>/dev/null || { pkill waybar 2>/dev/null; sleep 0.2; waybar & }
